# Qdrant (self-hosted, started via docker-compose.yml)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=support_docs

# Embedding model (runs locally, downloaded from HuggingFace on first use)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
RETRIEVER_TOP_K=5

# LLM (ollama by default — install with `brew install ollama` then `ollama pull llama3.2:3b`)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (only used when LLM_PROVIDER=openai)
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
