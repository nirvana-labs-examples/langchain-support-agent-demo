# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# Qdrant local storage (when running without Docker volume)
qdrant_storage/

# Dataset directories — stored as .zip files in git; extracted on first use
data/small/
data/medium/
data/large/

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Claude Code scratch state (lock files, worktrees, etc.)
.claude/

# Ansible inventory — contains live VM IPs and SSH key paths.
# `hosts.yml` is generated by `terraform output`; `manual-*.yml` files are
# user-authored entries for manually-provisioned VMs. None should be committed.
infra/ansible/inventory/*
!infra/ansible/inventory/.gitkeep
