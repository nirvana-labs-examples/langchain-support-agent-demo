# Qdrant (self-hosted, started via docker-compose.yml)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=support_docs

# Embedding model (runs locally, downloaded from HuggingFace on first use)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
RETRIEVER_TOP_K=5
