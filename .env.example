# OpenAI
OPENAI_API_KEY=sk-...

# Qdrant (self-hosted via Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=support_docs

# Agent settings
AGENT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVER_TOP_K=5

# Optional: Qdrant Cloud (leave blank to use self-hosted)
# QDRANT_API_KEY=
# QDRANT_URL=https://your-cluster.qdrant.tech
