# OpenAI (LLM only)
OPENAI_API_KEY=sk-...

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-...

# Qdrant (self-hosted via Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=support_docs

# Agent settings
AGENT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1024
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVER_TOP_K=5

# Optional: Qdrant Cloud (leave blank to use self-hosted)
# QDRANT_API_KEY=
# QDRANT_URL=https://your-cluster.qdrant.tech
